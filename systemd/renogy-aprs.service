[Unit]
Description=Renogy APRS Reporter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/renogy-rs
ExecStart=/usr/bin/renogy-aprs --callsign ${CALLSIGN}
Restart=on-failure
RestartSec=10
Environment=RUST_LOG=info
Environment=CALLSIGN=N0CALL

[Install]
WantedBy=default.target
