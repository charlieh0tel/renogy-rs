[Unit]
Description=Renogy BMS Collector
After=bluetooth.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/renogy-rs
ExecStart=/usr/bin/renogy-bms-collector ${COLLECTOR_ARGS}
Restart=on-failure
RestartSec=10
Environment=RUST_LOG=info
Environment=COLLECTOR_ARGS=bt2
ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes

[Install]
WantedBy=multi-user.target
