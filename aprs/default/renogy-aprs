# Configuration for renogy-aprs

# APRS SSID, i.e. callsign-N (e.g. W1AW-12)
# Required for renogy-aprs; will refuse to start with N0CALL.
#SSID=Y0URS-12

# Optional tactical source callsign (e.g. SOLAR1). When set, beacons are sourced
# from it and the operator's base callsign (SSID without the SSID suffix) is
# appended to each telemetry packet as an identifying comment. SSID still drives
# the APRS-IS login and passcode.
#APRS_TACTICAL=SOLAR1

# Station position. aprs.fi only collects telemetry for stations that have sent
# a position, so set one to appear on the map and have telemetry shown.
# Either give static coordinates (decimal degrees)...
#APRS_LATITUDE=40.7128
#APRS_LONGITUDE=-74.0060
# ...or read the position once at startup from gpsd:
#APRS_GPSD=localhost:2947
# Seconds to wait for a gpsd fix at startup. If no fix is obtained the service
# exits and systemd restarts it to retry. Raise it if the GPS is slow to lock.
#APRS_GPSD_FIX_TIMEOUT=30
# Optional APRS symbol (table selector + code) and position comment.
#APRS_SYMBOL=/-
#APRS_POSITION_COMMENT=Solar site

# Output transport: agw (TNC, default), aprs-is (internet), or both.
#APRS_TRANSPORT=agw

# APRS-IS server (used when APRS_TRANSPORT is aprs-is or both).
# The passcode is computed from the callsign automatically.
#APRSIS_HOST=rotate.aprs2.net
#APRSIS_PORT=14580
